TELEGRAM_TOKEN=your_bot_token_here
ADMIN_TG_ID=123456789

# OpenRouter — используем только бесплатные модели
OPENROUTER_API_KEY=sk-or-v1-...
AI_FAST_MODEL=google/gemma-4-31b-it:free
AI_SMART_MODEL=openai/gpt-oss-120b:free
AI_VISION_MODEL=google/gemma-4-31b-it:free

# Google Gemini — для vision задач (надёжнее чем OpenRouter для фото)
GEMINI_API_KEY=

# Fitbit (https://dev.fitbit.com/apps)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# TTS (optional, OpenAI-compatible endpoint)
TTS_URL=
TTS_VOICE=alloy

# Coach settings
NO_GYM_WARN_DAYS=2
STEPS_GOAL=8000
DAILY_CHECK_HOUR=9
EVENING_CHECK_HOUR=21
TZ=Europe/Moscow

DB_PATH=/data/iron_coach.db
